{
  "name": "@cp-research/muses-ui",
  "version": "0.1.1",
  "description": "CPR Automation Design System — React + Tailwind v4 component library (Muses)",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CP-research/Muses.git",
    "directory": "packages/muses-ui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./theme.css": "./dist/theme.css"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly && cp src/styles/theme.css dist/theme.css",
    "gen:llms": "node scripts/gen-llms.mjs",
    "storybook": "npm run gen:llms && storybook dev -p 6006",
    "build-storybook": "npm run gen:llms && storybook build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "^10.4.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0"
  }
}
